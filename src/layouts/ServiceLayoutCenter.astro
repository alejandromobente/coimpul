---
/**
 * * Centered services page layout. This has a title, description, main text, and an image if desired
 * The CTA and any other sections can be added in here so that all services pages have them
 */
import { Image } from "astro:assets";

// main layout
import BaseLayout from "./BaseLayout.astro";

// components
import Button from "@components/Button/Button.astro";
import CtaCardSplit from "@components/Cta/CtaCardSplit.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";

// default hero image
import defaultHeroImage from "@images/house.jpg";

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata; // an imported image
}

const { title, description, image = undefined } = Astro.props as Props;
const heroImage = image ?? defaultHeroImage;

const currLocale = getLocaleFromUrl(Astro.url);
const isEn = currLocale === "en";
const badgeText = isEn ? "Services" : "Servicios";
const ctaText = isEn ? "Request a quote" : "Solicitar presupuesto";
const contactHref = getLocalizedRoute(currLocale, "/contact");
---

<BaseLayout title={title} description={description} image={image}>

  <!-- hero side image -->
  <section
    id="service-hero"
    class="mt-20 overflow-clip bg-[url('/assets/pattern-light-big.svg')] bg-center bg-no-repeat dark:bg-[url('/assets/pattern-dark-big.svg')]"
  >
    <div class="site-container mx-auto px-4 pt-10 pb-10 md:pt-14 md:pb-14">
      <div class="-mx-4 flex flex-wrap items-center xl:items-center">

        <!-- texto izquierda -->
        <div class="mb-10 w-full px-4 md:mb-0 md:w-1/2">
          <div data-mos="fade-right" data-mos-anchor="#service-hero">
            <span
              class="bg-primary-500 mb-4 inline-flex items-center rounded-full px-2 py-px text-xs leading-5 text-white uppercase"
            >
              {badgeText}
            </span>
            <h1
              class="text-base-900 dark:text-base-100 mb-6 text-3xl leading-tight font-bold tracking-tight text-pretty lg:text-5xl lg:leading-tight"
            >
              {title}
            </h1>
          </div>
          <p
            class="description mb-8 text-lg text-pretty lg:text-xl"
            data-mos="fade-right"
            data-mos-delay=".1"
            data-mos-anchor="#service-hero"
          >
            {description}
          </p>
          <div
            class="mt-6 flex flex-wrap gap-4"
            data-mos="fade-right"
            data-mos-delay=".2"
            data-mos-anchor="#service-hero"
          >
            <Button variant="primary" href={contactHref}>
              {ctaText}
            </Button>
          </div>
        </div>

        <!-- imagen derecha -->
        <div class="w-full px-4 md:w-1/2">
          <div
            class="relative mx-auto max-w-max md:mr-0"
            data-mos="fade-left"
            data-mos-anchor="#service-hero"
          >
            <div class="overflow-hidden rounded-2xl">
              <Image
                src={heroImage}
                class="h-auto min-w-full max-h-[420px] object-cover"
                alt={title}
                loading="eager"
                width={600}
                densities={[1.5, 2]}
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>

  <!-- service details -->
  <section class="my-16">
    <div class="markdown-content site-container">
      <slot />
    </div>
  </section>

  <CtaCardSplit />
</BaseLayout>
