---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// Hero
import Hero from "@components/Hero/HeroCentered.astro";

// Features
import FeatureCardsSmall from "@components/Feature/FeatureCardsSmall.astro";

// Services
import ServicesSideImage from "@components/Services/ServicesSideImage.astro";

// Casos de éxito
import CasosDeExitoSection from "@components/CasosDeExito/CasosDeExitoSection.astro";

// Gallery
import FeatureLightboxMarquee from "@components/Feature/FeatureLightboxMarquee.astro";

// CTA
import CtaCardCenter from "@components/Cta/CtaCardCenter.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description}>

  <Hero />

  <!-- SERVICES -->
  <ServicesSideImage />

  <!-- Separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>

  <!-- FEATURES -->
  <FeatureCardsSmall />

  <!-- Separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>

  <!-- CASOS DE ÉXITO -->
  <CasosDeExitoSection />

  <!-- Separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>

  <!-- GALLERY -->
  <FeatureLightboxMarquee />

  <!-- Separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>

  <!-- CTA -->
  <CtaCardCenter />

  <!-- Separador -->
  <div class="site-container flex justify-center py-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>


</BaseLayout>
