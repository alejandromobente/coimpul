---
/**
 * * Hero centered
 */
import { Icon } from "astro-icon/components";

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { useTranslations, getLocalizedRoute } from "@js/translationUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const t = useTranslations(currLocale);
const isEn = currLocale === "en";

const contactHref = getLocalizedRoute(currLocale, "/contact");
const casosHref = getLocalizedRoute(currLocale, "/casos-de-exito");
---

<section
  id="hero-center"
  class="mt-20 overflow-x-clip bg-[url('/assets/pattern-light-big.svg')] bg-center bg-no-repeat dark:bg-[url('/assets/pattern-dark-big.svg')]"
>
  <div class="site-container mx-auto px-4 pt-10 pb-10">
    <div class="mx-auto mb-10 flex w-full max-w-[750px] flex-col justify-center px-4 text-center">
      <div data-mos="fade-right" data-mos-anchor="#hero-center">
        <span
          class="bg-primary-500 mb-4 inline-flex items-center rounded-full px-2 py-px text-xs leading-5 text-white uppercase"
        >
          {isEn ? "Industrial Construction" : "Construcciones Industriales"}
        </span>

        <h1
          class="text-base-900 dark:text-base-100 mb-6 text-3xl leading-tight font-bold tracking-tight text-pretty lg:text-5xl lg:leading-tight"
          set:html={t("hero_text")}
        />
      </div>
      <p
        class="description mb-10 text-lg text-pretty lg:text-xl"
        data-mos="fade-right"
        data-mos-delay=".1"
        data-mos-anchor="#hero-center"
      >
        {t("hero_description")}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button
          variant="primary"
          href={contactHref}
          data-mos="fade-right"
          data-mos-delay=".2"
          data-mos-anchor="#hero-center"
        >
          {isEn ? "Contact us" : "Contacto"}
        </Button>
        <Button
          variant="outline"
          href={casosHref}
          class="flex gap-1"
          data-mos="fade-right"
          data-mos-delay=".2"
          data-mos-anchor="#hero-center"
        >
          <Icon name="tabler/circle-check" class="h-5 w-5" aria-hidden="true" />
          <span>{isEn ? "Success stories" : "Casos de éxito"}</span>
        </Button>
      </div>
    </div>
  </div>

  <!-- Separador -->
  <div class="site-container flex justify-center pb-2">
    <div class="h-px w-full" style="background: linear-gradient(to right, transparent, #2fb2a8, transparent);"></div>
  </div>
</section>
