---
/**
 * * CTA card center with dark background and light text
 */

import { Icon } from "astro-icon/components";

// components
import Button from "@components/Button/Button.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getLocalizedRoute } from "@js/translationUtils";

// svgs
import Dots3 from "@src/icons/atlas/dots3.svg";
import WaveBgBasic from "@src/icons/atlas/wave-bg-basic.svg";

const currLocale = getLocaleFromUrl(Astro.url);
const isEn = currLocale === "en";
const contactHref = getLocalizedRoute(currLocale, "/contact");
---

<section class="py-10">
  <div class="site-container">
    <div class="bg-base-900 relative overflow-hidden rounded-md px-16 py-11 md:py-20">
      <Icon
        is:inline
        name="atlas/dots3"
        class="text-accent-3 absolute top-0 left-4 z-10 size-16"
        aria-hidden="true"
      />
      <Icon
        is:inline
        name="atlas/dots3"
        class="text-accent-1 absolute right-4 bottom-0 z-10 size-16"
        aria-hidden="true"
      />
      <Icon
        is:inline
        name="atlas/wave-bg-basic"
        class="absolute top-1/2 left-1/2 h-full w-auto -translate-x-1/2 -translate-y-1/2 object-cover text-black/5"
        aria-hidden="true"
      />

      <div
        class="relative z-20 -m-3 mx-auto flex max-w-lg flex-col flex-wrap items-center gap-4 text-center"
      >
        {isEn ? (
          <>
            <h2 class="mb-6 text-4xl/normal font-bold text-white">
              Have a project in mind? Let's talk.
            </h2>
            <Button variant="primary" href={contactHref} class="shadow-none">
              Contact us
            </Button>
          </>
        ) : (
          <>
            <h2 class="mb-6 text-4xl/normal font-bold text-white">
              ¿Tienes un proyecto en mente? Hablemos.
            </h2>
            <Button variant="primary" href={contactHref} class="shadow-none">
              Contacto
            </Button>
          </>
        )}
      </div>
    </div>
  </div>
</section>
