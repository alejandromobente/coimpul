---
import { Image } from "astro:assets";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData, getLocalizedRoute } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

// images
import logo from "@images/logo_coimpul.webp";
import logoBlanco from "@images/logo_coimpul_blanco.png";
---

<a
  class="primary-focus flex items-center align-middle"
  href={getLocalizedRoute(currLocale, "/")}
>
  <!-- logo light mode -->
  <Image
    src={logo}
    alt={siteData.name}
    loading="eager"
    height={56}
    class="h-14 w-auto dark:hidden"
  />
  <!-- logo dark mode -->
  <Image
    src={logoBlanco}
    alt={siteData.name}
    loading="eager"
    height={56}
    class="h-14 w-auto hidden dark:block"
  />
</a>
