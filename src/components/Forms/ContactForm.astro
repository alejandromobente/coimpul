---
import Button from "@components/Button/Button.astro";

interface Props {
  locale?: "es" | "en";
}

const { locale = "es" } = Astro.props;
const isEn = locale === "en";

const t = {
  fname: isEn ? "First name" : "Nombre",
  lname: isEn ? "Last name" : "Apellidos",
  address: isEn ? "Street address" : "Dirección",
  city: isEn ? "City" : "Ciudad",
  state: isEn ? "Province" : "Provincia",
  zip: isEn ? "Zip code" : "Código postal",
  email: isEn ? "Email" : "Email",
  phone: isEn ? "Phone number" : "Teléfono",
  timeframe: isEn ? "Desired time frame for the work to be completed" : "Plazo deseado para ejecutar el trabajo",
  services: isEn
    ? "Please describe the services desired"
    : "Describe brevemente los servicios que necesitas",
  submit: isEn ? "Submit" : "Enviar",
  sending: isEn ? "Sending…" : "Enviando…",
  successTitle: isEn ? "Message sent!" : "¡Mensaje enviado!",
  successBody: isEn
    ? "We'll get back to you as soon as possible."
    : "Nos pondremos en contacto contigo lo antes posible.",
  errorTitle: isEn ? "Something went wrong" : "Algo ha salido mal",
  errorBody: isEn
    ? "Please try again or write to us directly at coimpul@coimpul.com"
    : "Inténtalo de nuevo o escríbenos directamente a coimpul@coimpul.com",
};
---

<section id="contact" class="mx-auto min-w-fit max-w-3xl rounded-lg">
  <form
    id="contact-form"
    name="contact"
    class="flex flex-col gap-4"
    data-locale={locale}
    data-label-submit={t.submit}
    data-label-sending={t.sending}
    novalidate
  >
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="flex flex-col">
        <label for="contact-fname" class="form__label sr-only">
          {t.fname} <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          class="form__input"
          name="fname"
          id="contact-fname"
          placeholder={t.fname}
          required
        />
      </div>
      <div class="flex flex-col">
        <label for="contact-lname" class="form__label sr-only">
          {t.lname} <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          class="form__input"
          name="lname"
          id="contact-lname"
          placeholder={t.lname}
          required
        />
      </div>
    </div>

    <div>
      <label for="contact-address" class="form__label sr-only">
        {t.address} <span class="text-red-600">*</span>
      </label>
      <input
        type="text"
        class="form__input"
        name="address"
        id="contact-address"
        placeholder={t.address}
        required
      />
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div class="flex flex-col">
        <label for="contact-city" class="form__label sr-only">
          {t.city} <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          class="form__input"
          name="city"
          id="contact-city"
          placeholder={t.city}
          required
        />
      </div>
      <div class="flex flex-col">
        <label for="contact-state" class="form__label sr-only">
          {t.state} <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          class="form__input"
          name="state"
          id="contact-state"
          placeholder={t.state}
          required
        />
      </div>
      <div class="flex flex-col">
        <label for="contact-zip" class="form__label sr-only">
          {t.zip} <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          class="form__input"
          name="zip"
          id="contact-zip"
          placeholder={t.zip}
          required
        />
      </div>
    </div>

    <div>
      <label for="contact-email" class="form__label sr-only">
        {t.email} <span class="text-red-600">*</span>
      </label>
      <input
        type="email"
        class="form__input"
        name="email"
        id="contact-email"
        inputmode="email"
        placeholder={t.email}
        required
      />
    </div>

    <div>
      <label for="contact-phone" class="form__label sr-only">
        {t.phone} <span class="text-red-600">*</span>
      </label>
      <input
        type="tel"
        class="form__input"
        name="phone"
        id="contact-phone"
        inputmode="tel"
        placeholder={t.phone}
        required
      />
    </div>

    <div>
      <label for="contact-timeframe" class="form__label sr-only">
        {t.timeframe} <span class="text-red-600">*</span>
      </label>
      <input
        type="text"
        class="form__input"
        name="timeframe"
        id="contact-timeframe"
        placeholder={t.timeframe}
        required
      />
    </div>

    <div>
      <label for="contact-services" class="form__label sr-only">
        {t.services} <span class="text-red-600">*</span>
      </label>
      <textarea
        name="services"
        class="form__input"
        id="contact-services"
        rows="4"
        placeholder={t.services}
        required></textarea>
    </div>

    <Button variant="primary" type="submit" id="contact-submit">{t.submit}</Button>
  </form>

  <!-- Success -->
  <div id="contact-success" class="hidden rounded-lg bg-green-50 p-6 text-center dark:bg-green-950">
    <p class="text-lg font-semibold text-green-800 dark:text-green-200">{t.successTitle}</p>
    <p class="mt-2 text-green-700 dark:text-green-300">{t.successBody}</p>
  </div>

  <!-- Error -->
  <div id="contact-error" class="hidden rounded-lg bg-red-50 p-4 dark:bg-red-950">
    <p class="font-semibold text-red-800 dark:text-red-200">{t.errorTitle}</p>
    <p class="mt-1 text-sm text-red-700 dark:text-red-300">{t.errorBody}</p>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  if (form) {
    const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;
    const successEl = document.getElementById("contact-success");
    const errorEl = document.getElementById("contact-error");
    const labelSubmit = form.dataset.labelSubmit ?? "Enviar";
    const labelSending = form.dataset.labelSending ?? "Enviando…";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = labelSending;
      }
      errorEl?.classList.add("hidden");

      const data = Object.fromEntries(new FormData(form).entries());

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.classList.add("hidden");
          successEl?.classList.remove("hidden");
        } else {
          throw new Error("non-ok response");
        }
      } catch {
        errorEl?.classList.remove("hidden");
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = labelSubmit;
        }
      }
    });
  }
</script>
