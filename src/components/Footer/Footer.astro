---
// components
import FooterLink from "@components/Footer/FooterLink.astro";
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import SocialIcon from "@components/SocialIcon/SocialIcon.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData, getLocalizedRoute } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const isEn = currLocale === "en";

const homeHref = getLocalizedRoute(currLocale, "/");
const servicesHref = `${homeHref}#services-side-image`;

const today = new Date();
---

<footer class="text-base-500 overflow-x-clip pt-20 pb-16 font-medium">
  <div class="site-container">
    <div class="mt-6 flex flex-wrap items-center justify-between gap-6">
      <SiteLogo />
      <div class="flex flex-wrap gap-x-4">
        <FooterLink href={servicesHref}>
          {isEn ? "Services" : "Servicios"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/casos-de-exito")}>
          {isEn ? "Success Stories" : "Casos de Éxito"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/blog")}>Blog</FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/contact")}>
          {isEn ? "Contact" : "Contacto"}
        </FooterLink>
      </div>
    </div>
  </div>
  <div class="border-t-base-200/50 text-base-400 mt-6 border-t text-sm">
    <div class="site-container mt-6 flex flex-wrap justify-between gap-x-6 gap-y-4">
      <!-- Copyright -->
      <div class="my-auto">
        &copy; {today.getFullYear()}
        {" "}{siteData.name}. {isEn ? "All rights reserved." : "Todos los derechos reservados."}
      </div>

      <!-- Legal links -->
      <div class="my-auto flex flex-wrap gap-x-4 gap-y-1">
        <FooterLink href={getLocalizedRoute(currLocale, "/aviso-legal")}>
          {isEn ? "Legal Notice" : "Aviso Legal"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/privacy-policy")}>
          {isEn ? "Privacy Policy" : "Política de Privacidad"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/politica-cookies")}>
          {isEn ? "Cookie Policy" : "Política de Cookies"}
        </FooterLink>
        <FooterLink href={getLocalizedRoute(currLocale, "/declaracion-accesibilidad")}>
          {isEn ? "Accessibility" : "Accesibilidad"}
        </FooterLink>
      </div>

      <!-- Socials -->
      <div class="flex gap-4">
        <SocialIcon
          href="https://instagram.com"
          icon="tabler/brand-instagram"
          social="instagram"
        />
        <SocialIcon
          href="https://facebook.com"
          icon="tabler/brand-facebook"
          social="facebook"
        />
        <SocialIcon
          href="https://linkedin.com"
          icon="tabler/brand-linkedin"
          social="linkedin"
        />
      </div>
    </div>
  </div>
</footer>
