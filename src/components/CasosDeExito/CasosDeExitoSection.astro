---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

// components
import Badge from "@components/Badge/Badge.astro";
import Button from "@components/Button/Button.astro";

// data
const allCasos = await getCollection("casosDeExito", ({ data }) => data.draft !== true);
const casos = allCasos.sort((a, b) => a.data.title.localeCompare(b.data.title));
const categories = [...new Set(casos.map((c) => c.data.category))].sort();

const categoryLabels: Record<string, string> = {
  industrial: "Industrial",
  comercial: "Comercial",
  infraestructuras: "Infraestructuras",
  residencial: "Residencial",
};

const categoryGradients: Record<string, string> = {
  industrial: "from-orange-900 to-orange-700",
  comercial: "from-slate-800 to-slate-600",
  infraestructuras: "from-stone-800 to-stone-600",
  residencial: "from-zinc-800 to-zinc-600",
};
---

<section id="casos-home" class="py-10">
  <div class="site-container">

    <!-- Header -->
    <div class="mx-auto mb-10 text-center md:max-w-3xl" data-mos="fade-up">
      <Badge>Casos de éxito</Badge>
      <h2 class="h2 mb-4 mt-1">Proyectos que hablan por sí solos</h2>
      <p class="description text-lg text-pretty md:text-xl">
        Una selección de trabajos reales que reflejan nuestra experiencia,
        rigor técnico y compromiso con cada cliente.
      </p>
    </div>

    <!-- Filtros -->
    <div class="mb-10 flex flex-wrap justify-center gap-3" data-mos="fade-up" data-mos-delay=".1">
      <button
        data-cfilter="todos"
        class="casos-filter-btn casos-filter-btn--active rounded-full border border-primary-500 bg-primary-500 px-5 py-2 text-sm font-medium text-white transition-all"
      >
        Todos
      </button>
      {
        categories.map((cat) => (
          <button
            data-cfilter={cat}
            class="casos-filter-btn rounded-full border border-base-300 bg-white px-5 py-2 text-sm font-medium text-base-600 transition-all hover:border-primary-500 hover:text-primary-500 dark:border-base-700 dark:bg-base-900 dark:text-base-300"
          >
            {categoryLabels[cat] ?? cat}
          </button>
        ))
      }
    </div>

    <!-- Grid -->
    <div
      id="casos-home-grid"
      class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
      data-mos="fade-up"
      data-mos-delay=".15"
    >
      {
        casos.map((caso) => (
          <a
            href={`/casos-de-exito/${caso.id}`}
            data-ccat={caso.data.category}
            class="caso-home-card group relative overflow-hidden rounded-xl"
          >
            <!-- Imagen o gradiente -->
            <div class="aspect-[4/3] w-full overflow-hidden">
              {caso.data.image ? (
                <Image
                  src={caso.data.image}
                  alt={caso.data.title}
                  width={800}
                  height={600}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              ) : (
                <div
                  class={`h-full w-full bg-gradient-to-br transition-transform duration-500 group-hover:scale-105 ${categoryGradients[caso.data.category] ?? "from-base-800 to-base-600"}`}
                />
              )}
            </div>

            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />

            <!-- Texto -->
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <span class="mb-2 inline-block rounded-full bg-primary-500/90 px-3 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">
                {categoryLabels[caso.data.category] ?? caso.data.category}
              </span>
              <h3 class="text-lg font-bold leading-tight text-white">{caso.data.title}</h3>
              <p class="mt-1 line-clamp-2 text-sm text-white/75">{caso.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Ver todos -->
    <div class="mt-12 text-center" data-mos="fade-up" data-mos-delay=".2">
      <Button variant="outline" href="/casos-de-exito" arrow="right">
        Ver todos los proyectos
      </Button>
    </div>

  </div>
</section>

<script>
  function initCasosFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".casos-filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".caso-home-card");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.cfilter!;

        // estilos activo/inactivo
        buttons.forEach((b) => {
          b.classList.remove("bg-primary-500", "border-primary-500", "text-white");
          b.classList.add(
            "border-base-300",
            "bg-white",
            "text-base-600",
            "dark:border-base-700",
            "dark:bg-base-900",
            "dark:text-base-300",
          );
        });
        btn.classList.add("bg-primary-500", "border-primary-500", "text-white");
        btn.classList.remove(
          "border-base-300",
          "bg-white",
          "text-base-600",
          "dark:border-base-700",
          "dark:bg-base-900",
          "dark:text-base-300",
        );

        // mostrar/ocultar cards
        cards.forEach((card) => {
          card.style.display =
            filter === "todos" || card.dataset.ccat === filter ? "" : "none";
        });
      });
    });
  }

  initCasosFilter();
  document.addEventListener("astro:after-swap", initCasosFilter);
</script>
