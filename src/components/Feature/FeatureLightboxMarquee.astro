---
/**
 * * Single row logo marquee
 * JS allows the animation to pause while you hover over it.
 */

// components
import Badge from "@components/Badge/Badge.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";

const currLocale = getLocaleFromUrl(Astro.url);
const isEn = currLocale === "en";

// Placeholder slots — replace with actual logo imports when ready
const logoCount = 8;
const logos = Array.from({ length: logoCount }, (_, i) => i + 1);
---

<section
  id="feature-gallery-marquee"
  class="bg-[url('/assets/pattern-light-big.svg')] bg-center bg-no-repeat py-10 dark:bg-[url('/assets/pattern-dark-big.svg')]"
>
  <div class="site-container flex justify-center">
    <div class="mx-auto mb-16 text-center md:max-w-4xl" data-mos="fade-up">
      {isEn ? (
        <>
          <Badge>Partners</Badge>
          <h2 class="h2">Trusted by industry leaders</h2>
          <p class="description mt-4 text-lg text-pretty md:text-xl">
            We collaborate with the best suppliers and partners in the sector.
          </p>
        </>
      ) : (
        <>
          <Badge>Partners</Badge>
          <h2 class="h2">La confianza de los líderes del sector</h2>
          <p class="description mt-4 text-lg text-pretty md:text-xl">
            Colaboramos con los mejores proveedores y socios del sector.
          </p>
        </>
      )}
    </div>
  </div>

  <div class="marquee-wrapper relative overflow-hidden">
    <!-- marquee row -->
    <div class="marquee-row relative flex gap-12 overflow-hidden">
      <div
        class="animate-marquee-gallery flex min-w-full shrink-0 items-center justify-around gap-12"
      >
        {
          logos.map((n) => (
            <div
              class="flex h-16 w-36 shrink-0 items-center justify-center rounded-md border border-dashed border-base-300 bg-base-100 dark:border-base-600 dark:bg-base-800"
              aria-label={`Logo ${n}`}
            >
              <span class="text-xs font-medium text-base-400 dark:text-base-500">Logo {n}</span>
            </div>
          ))
        }
      </div>
      <div
        aria-hidden="true"
        class="animate-marquee-gallery flex min-w-full shrink-0 items-center justify-around gap-12"
      >
        {
          logos.map((n) => (
            <div
              class="flex h-16 w-36 shrink-0 items-center justify-center rounded-md border border-dashed border-base-300 bg-base-100 dark:border-base-600 dark:bg-base-800"
            >
              <span class="text-xs font-medium text-base-400 dark:text-base-500">Logo {n}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const setupMarquee = () => {
    const marqueeRow = document.querySelector(".marquee-row");

    marqueeRow?.addEventListener("mouseover", () => {
      marqueeRow.querySelectorAll(".animate-marquee-gallery").forEach((el) => {
        el.classList.add("pause");
      });
    });

    marqueeRow?.addEventListener("mouseout", () => {
      marqueeRow.querySelectorAll(".animate-marquee-gallery").forEach((el) => {
        el.classList.remove("pause");
      });
    });
  };

  setupMarquee();

  document.addEventListener("astro:after-swap", () => {
    setupMarquee();
  });
</script>
